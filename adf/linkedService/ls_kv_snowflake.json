{
	"name": "ls_kv_snowflake",
	"properties": {
		"parameters": {
			"pAccount": {
				"type": "string",
				"defaultValue": "GUFFHNC-GGB13378"
			},
			"pWarehouse": {
				"type": "string",
				"defaultValue": "COMPUTE_WH"
			},
			"pDatabase": {
				"type": "string",
				"defaultValue": "LICENSING_DB"
			},
			"pUser": {
				"type": "string",
				"defaultValue": "PAVANUSDE"
			}
		},
		"annotations": [],
		"type": "SnowflakeV2",
		"typeProperties": {
			"authenticationType": "KeyPair",
			"accountIdentifier": "@{linkedService().pAccount}",
			"user": "@{linkedService().pUser}",
			"database": "@{linkedService().pDatabase}",
			"warehouse": "@{linkedService().pWarehouse}",
			"privateKey": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "ls_keyvault",
					"type": "LinkedServiceReference"
				},
				"secretName": "snowflake-private-key"
			},
			"useUtcTimestamps": false
		},
		"version": "1.1"
	}
}